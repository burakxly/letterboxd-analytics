# ─── Render Backend ────────────────────────────────────────
# Otomatik olarak Render tarafından set edilir — manuel set etme
RENDER_EXTERNAL_URL=https://your-service.onrender.com

# Vercel frontend URL — CORS whitelist için (Render env vars'a ekle)
FRONTEND_URL=https://your-app.vercel.app

# ─── Vercel Frontend ───────────────────────────────────────
# Next.js'in API isteklerini yönlendirdiği backend URL
# Vercel dashboard'a NEXT_PUBLIC_API_URL olarak ekle
NEXT_PUBLIC_API_URL=https://your-service.onrender.com

# ─── Web Scraper (yerel çalıştırma) ───────────────────────
# web_scraper.py için TMDB ve OMDB API anahtarları
# Render üzerinde çalışmaz; sadece yerel enrichment için
TMDB_API_KEY=your_tmdb_api_key_here
OMDB_API_KEY=your_omdb_api_key_here

# ─── İş Mantığı (isteğe bağlı) ────────────────────────────
# Yıllık film izleme hedefi — varsayılan: 200
ANNUAL_GOAL=200
